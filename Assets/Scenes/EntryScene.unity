  m_Script: {fileID: 11500000, guid: 8b26c5c4280ba404e8442bf8d4e67c98, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CinematicController
  dialogueText: {fileID: 1341871553}
  dialogueLines:
  - I used to belive wars had rules
  - Lines you didn't cross
  - They erased those lines
  - No Uniforms
  - No Warnings
  - No Mercy
  - You still think this is war ?
  - This is Correction
  - Your world is weak
  - Divided
  - Predictable
  - We are Simply..... accelerating the inevitable
  - You hide in the Dark
  - You strike Civilians
  - You call that Strength ?
  - I call it efficiency
  - and You....
  - You're already too late
  - Maybe
  - But you made one Mistake
  - Ohh??
  - You left me Alive. And now....
  - You're in my Shadows
  isVillainLine: 0000000000000101010101010000000101010000010000
  heroImage: {fileID: 1912320885}
  villainImage: {fileID: 1807747737}
  cinematicPanel: {fileID: 394780334}
  startScreenPanel: {fileID: 1560606731}
  typingSpeed: 0.03
  delayBetweenLines: 1.5
  holdDurationToSkip: 1.5
